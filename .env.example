# API Configuration
REACT_NATIVE_API_BASE_URL=http://localhost:3000/api
REACT_NATIVE_API_TIMEOUT=10000

# Firebase Configuration (for notifications)
REACT_NATIVE_FIREBASE_PROJECT_ID=your_project_id
REACT_NATIVE_FIREBASE_API_KEY=your_api_key
REACT_NATIVE_FIREBASE_AUTH_DOMAIN=your_auth_domain
REACT_NATIVE_FIREBASE_APP_ID=your_app_id
REACT_NATIVE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# External API Keys (if needed)
REACT_NATIVE_EXTERNAL_API_KEY=your_external_api_key

# Environment
REACT_NATIVE_ENV=development
